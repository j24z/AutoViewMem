# OpenAI-compatible LLM endpoint
ARK_API_KEY=
ARK_BASE_URL=http://localhost:8000/v1
ARK_MODEL=qwen3-8b

# Embedding endpoint
EMBEDDING_API_KEY=empty
EMBEDDING_BASE_URL=http://localhost:8000/v1
EMBEDDING_MODEL=intfloat/e5-base-v2
EMBEDDING_SIZE=768

# Vector store
QDRANT_URL=http://localhost:6333
COLLECTION_NAME=autoviewmem_demo
MEM0_COLLECTION_NAME=autoviewmem_mem0

# Runtime options
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=8192
DATA_DIR=data/locomo
